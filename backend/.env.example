# Async PostgreSQL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kognis

# Optional: tune for low-memory hosts (defaults are already small)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=0

# openai | anthropic
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# MCQ generation: max questions per LLM request (large exams use multiple calls). Default 20.
# MCQ_MAX_QUESTIONS_PER_BATCH=20

# Admin JWT (required for password login). Use a long random string, e.g. openssl rand -hex 32
JWT_SECRET=

# Optional legacy: still works for scripts/curl as X-Admin-Key if JWT is not sent
ADMIN_API_KEY=

# Comma-separated browser origins, e.g. http://localhost:3000
ALLOWED_ORIGINS=
