# Async PostgreSQL (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kognis

# Optional: tune for low-memory hosts (defaults are already small)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=0

# openai | anthropic
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Required for POST /api/v1/admin/exams/generate
ADMIN_API_KEY=change-me

# Comma-separated browser origins, e.g. http://localhost:3000
ALLOWED_ORIGINS=
